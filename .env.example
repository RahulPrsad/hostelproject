# Server
PORT=3001

# Database - use MongoDB Atlas connection string in production
MONGODB_URI=

# Auth
JWT_SECRET="your/-secret_code"
JWT_EXPIRE=7d

# Email (e.g. Gmail app password)
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587
NODEMAILER_USER=your-email@gmail.com
NODEMAILER_PASS=your-gmail-app-password

# App URL - set to your deployed URL (e.g. https://your-app.onrender.com)
APP_URL=https://hostelproject-omega.vercel.app/login

# Optional first admin account for npm run seed:admin
ADMIN_EMAIL=***********
ADMIN_PASSWORD=******
