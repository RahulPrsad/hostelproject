<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scan QR - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>
  <div class="flex flex-1 flex-col items-stretch md:flex-row">
    <%- include('../partials/sidebar') %>
    <main class="min-w-0 flex-1 p-4 md:p-6">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">Scan Student QR</h1>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="rounded-lg bg-white p-4 shadow">
          <div id="reader" class="w-full"></div>
          <button type="button" id="startBtn" class="mt-2 hidden bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">Retry Camera</button>
          <button type="button" id="stopBtn" class="mt-2 ml-2 bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700" style="display:none">Stop</button>
        </div>
        <div id="studentCard" class="rounded-lg bg-white p-6 shadow hidden">
          <h2 class="font-semibold text-lg mb-2">Student Details</h2>
          <p id="sName" class="text-gray-800"></p>
          <p id="sEmail" class="text-gray-600 text-sm"></p>
          <p id="sBranch" class="text-gray-600 text-sm"></p>
          <p id="sYear" class="text-gray-600 text-sm"></p>
          <p class="mt-2">Parent: <a id="sParentLink" href="#" class="text-indigo-600 hover:underline">Call Parent</a></p>
          <div id="leaveStatusPanel" class="mt-4 hidden rounded border p-4 text-sm"></div>
          <input type="hidden" id="studentId" value="">
          <div class="mt-4 space-y-2">
            <button type="button" id="issueFruitBtn" class="block w-full bg-green-600 text-white py-2 rounded hover:bg-green-700">Issue Fruit</button>
            <button type="button" id="issueEquipBtn" class="block w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">Issue Equipment</button>
            <a id="leaveRequestBtn" href="/admin/leaves" class="hidden block w-full rounded bg-amber-600 py-2 text-center text-white hover:bg-amber-700">Leave Request</a>
          </div>
          <div class="mt-6 border-t pt-4">
            <div class="mb-3 flex items-center justify-between gap-3">
              <h3 class="font-semibold text-gray-800">Return Equipment</h3>
              <button type="button" id="refreshEquipmentBtn" class="text-sm text-indigo-600 hover:underline">Refresh</button>
            </div>
            <div id="activeEquipmentList" class="space-y-3 text-sm text-gray-600">Scan a student to view active equipment.</div>
          </div>
          <div id="returnResultPanel" class="mt-4 hidden rounded border border-amber-200 bg-amber-50 p-4">
            <p id="returnResultText" class="text-sm font-medium text-amber-900"></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <button type="button" id="agreeReturnBtn" class="rounded bg-green-600 px-4 py-2 text-sm text-white hover:bg-green-700">Agree</button>
              <button type="button" id="cancelReturnBtn" class="rounded border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-white">Close</button>
            </div>
          </div>
        </div>
      </div>
      <div id="capturePanel" class="fixed inset-0 z-40 hidden bg-black/70 p-4">
        <div class="mx-auto flex h-full max-w-lg flex-col justify-center">
          <div class="rounded-lg bg-white p-4 shadow-xl">
            <div class="mb-3 flex items-center justify-between gap-3">
              <h2 id="captureTitle" class="font-semibold text-gray-900">Capture Equipment Photo</h2>
              <button type="button" id="cancelCaptureBtn" class="rounded border border-gray-300 px-3 py-1 text-sm text-gray-700 hover:bg-gray-50">Close</button>
            </div>
            <video id="captureVideo" autoplay playsinline muted class="aspect-video w-full rounded bg-black object-cover"></video>
            <canvas id="captureCanvas" class="hidden"></canvas>
            <button type="button" id="captureImageBtn" class="mt-3 w-full rounded bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">Capture Photo</button>
          </div>
        </div>
      </div>
      <div id="toast" class="fixed bottom-4 right-4 hidden px-4 py-2 rounded shadow-lg z-50"></div>
    </main>
  </div>
  <%- include('../partials/footer') %>
  <script src="/js/equipmentPhotos.js"></script>
  <script src="/js/scan.js"></script>
</body>
</html>
