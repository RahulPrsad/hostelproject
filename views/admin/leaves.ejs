<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Leaves - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>
  <div class="flex flex-1 flex-col items-stretch md:flex-row">
    <%- include('../partials/sidebar') %>
    <main class="min-w-0 flex-1 p-4 md:p-6">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">Leave Applications</h1>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mb-4 p-3 bg-green-100 text-green-700 rounded"><%= success %></div>
      <% } %>
      <% const yearGroups = ['1', '2', '3', '4']; %>
      <div class="mb-4 flex flex-wrap gap-2">
        <% yearGroups.forEach(year => { %>
          <% const yearCount = leaves.filter(l => String((l.studentId && l.studentId.year) || '').trim() === year || String((l.studentId && l.studentId.year) || '').trim() === year + ' Year').length; %>
          <button type="button" data-year-tab="<%= year %>" class="rounded border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
            Year <%= year %> <span class="text-slate-500">(<%= yearCount %>)</span>
          </button>
        <% }); %>
      </div>
      <div class="space-y-6">
        <% yearGroups.forEach(year => { %>
          <% const yearLeaves = leaves.filter(l => String((l.studentId && l.studentId.year) || '').trim() === year || String((l.studentId && l.studentId.year) || '').trim() === year + ' Year'); %>
          <section data-year-panel="<%= year %>" class="hidden bg-white rounded-lg shadow overflow-hidden">
            <div class="border-b bg-gray-50 px-4 py-3">
              <h2 class="font-semibold text-gray-800">Year <%= year %> Leave Applications</h2>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="bg-gray-50 border-b"><th class="text-left p-3">Student</th><th class="text-left p-3">From - To</th><th class="text-left p-3">Reason</th><th class="text-left p-3">Status</th><th class="text-left p-3">Action</th></tr></thead>
                <tbody>
                  <% yearLeaves.forEach(l => { %>
                    <tr class="border-b <%= String(l.studentId && l.studentId._id) === focusStudentId ? 'bg-indigo-50' : '' %>">
                  <td class="p-3">
                    <%= l.studentId ? l.studentId.name : 'N/A' %><br>
                    <span class="text-gray-500 text-xs"><%= l.studentId ? l.studentId.email : '' %></span>
                    <% if (l.studentId && l.studentId.parentPhone) { %>
                      <br><span class="text-gray-500 text-xs">Parent: <%= l.studentId.parentName || 'Parent' %> · <%= l.studentId.parentPhone %></span>
                    <% } %>
                  </td>
                  <td class="p-3"><%= new Date(l.fromDate).toLocaleDateString() %> - <%= new Date(l.toDate).toLocaleDateString() %></td>
                  <td class="p-3"><%= l.reason %></td>
                  <td class="p-3"><span class="px-2 py-0.5 rounded text-xs <%= l.status === 'approved' ? 'bg-green-100' : l.status === 'rejected' ? 'bg-red-100' : 'bg-yellow-100' %>"><%= l.status %></span></td>
                  <td class="p-3 align-top">
                    <% if (l.status === 'pending') { %>
                      <div class="flex flex-wrap gap-2">
                        <% if (l.studentId && l.studentId.parentPhone) { %>
                          <% const parentDialNumber = String(l.studentId.parentPhone).replace(/[^\d+]/g, ''); %>
                          <a href="tel:<%= parentDialNumber %>" data-call-parent-for="<%= l._id %>" class="text-indigo-600 hover:underline">Call Parent</a>
                        <% } else { %>
                          <span class="text-xs text-gray-500">No parent phone</span>
                        <% } %>
                        <form action="/admin/leaves/<%= l._id %>/approve" method="POST" class="inline">
                          <button type="submit" data-approve-leave="<%= l._id %>" <%= l.studentId && l.studentId.parentPhone ? 'disabled' : '' %> class="text-green-600 hover:underline disabled:text-gray-400 disabled:no-underline">Approve</button>
                        </form>
                        <form action="/admin/leaves/<%= l._id %>/reject" method="POST" class="inline"><button type="submit" class="text-red-600 hover:underline">Reject</button></form>
                      </div>
                    <% } else { %>-<% } %>
                  </td>
                </tr>
                  <% }); %>
                  <% if (yearLeaves.length === 0) { %><tr><td colspan="5" class="p-4 text-gray-500">No applications for year <%= year %></td></tr><% } %>
                </tbody>
              </table>
            </div>
          </section>
        <% }); %>
      </div>
    </main>
  </div>
  <%- include('../partials/footer') %>
  <script>
    (function () {
      var tabs = Array.prototype.slice.call(document.querySelectorAll('[data-year-tab]'));
      var panels = Array.prototype.slice.call(document.querySelectorAll('[data-year-panel]'));
      var initialYear = '1';
      var focusedRow = document.querySelector('tr.bg-indigo-50');
      if (focusedRow) {
        var focusedPanel = focusedRow.closest('[data-year-panel]');
        if (focusedPanel) initialYear = focusedPanel.getAttribute('data-year-panel');
      }

      function selectYear(year) {
        tabs.forEach(function (tab) {
          var active = tab.getAttribute('data-year-tab') === year;
          tab.className = active
            ? 'rounded border border-indigo-600 bg-indigo-600 px-4 py-2 text-sm font-medium text-white'
            : 'rounded border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50';
        });
        panels.forEach(function (panel) {
          panel.classList.toggle('hidden', panel.getAttribute('data-year-panel') !== year);
        });
      }

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          selectYear(tab.getAttribute('data-year-tab'));
        });
      });
      selectYear(initialYear);
    })();

    document.querySelectorAll('[data-call-parent-for]').forEach(function (link) {
      link.addEventListener('click', function () {
        var id = link.getAttribute('data-call-parent-for');
        var approve = document.querySelector('[data-approve-leave="' + id + '"]');
        if (approve) approve.disabled = false;
      });
    });
  </script>
</body>
</html>
