<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>
  <div class="flex flex-1 flex-col items-stretch md:flex-row">
    <%- include('../partials/sidebar') %>
    <main class="min-w-0 flex-1 p-4 md:p-6">
      <h1 class="mb-6 text-2xl font-bold text-gray-800">Generate Report</h1>
      <form id="reportForm" class="max-w-lg rounded-lg bg-white p-6 shadow">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fromDate" class="mb-1 block text-sm font-medium text-gray-700">From date</label>
            <input id="fromDate" name="from" type="date" required value="<%= defaultFrom %>" class="w-full rounded border border-gray-300 px-3 py-2">
          </div>
          <div>
            <label for="toDate" class="mb-1 block text-sm font-medium text-gray-700">To date</label>
            <input id="toDate" name="to" type="date" required value="<%= defaultTo %>" class="w-full rounded border border-gray-300 px-3 py-2">
          </div>
        </div>
        <button type="submit" id="generateReportBtn" class="mt-5 w-full rounded bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">Generate Report</button>
        <p id="reportStatus" class="mt-3 hidden text-sm"></p>
      </form>
    </main>
  </div>
  <%- include('../partials/footer') %>
  <script src="/js/reportShare.js"></script>
</body>
</html>
