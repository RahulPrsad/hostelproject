<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>
  <div class="flex flex-1 flex-col items-stretch md:flex-row">
    <%- include('../partials/sidebar') %>
    <main class="min-w-0 flex-1 p-4 md:p-6">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">Admin Dashboard</h1>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        <a href="/admin/students" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">Total Students</p>
          <p class="text-2xl font-semibold"><%= totalStudents %></p>
        </a>
        <a href="/admin/students?status=present" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">Present Today</p>
          <p class="text-2xl font-semibold text-green-700"><%= presentStudents %></p>
        </a>
        <a href="/admin/students?status=on-leave" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">On Leave Today</p>
          <p class="text-2xl font-semibold text-amber-700"><%= onLeaveStudents %></p>
        </a>
        <a href="/admin/equipment" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">Equipment Issued</p>
          <p class="text-2xl font-semibold"><%= equipmentIssued %></p>
        </a>
        <a href="/admin/fruit" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">Fruit This Week</p>
          <p class="text-2xl font-semibold"><%= fruitThisWeek %></p>
        </a>
        <a href="/admin/complaints" class="block rounded-lg bg-white p-4 shadow transition hover:-translate-y-0.5 hover:shadow-md">
          <p class="text-gray-600 text-sm">Open Complaints</p>
          <p class="text-2xl font-semibold"><%= complaintCount %></p>
        </a>
      </div>
    </main>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
