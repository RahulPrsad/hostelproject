<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <main class="flex flex-1 items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg">
      <div class="mb-6 text-center">
        <img src="/images/ramdeobaba-university-logo.png" alt="Ramdeobaba University" class="mx-auto h-20 w-20 rounded-full object-cover">
        <p class="mt-3 text-sm font-semibold text-slate-700">Ramdeobaba University Hostel</p>
      </div>
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-slate-900">Login</h1>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 rounded-2xl bg-red-100 p-3 text-red-700" id="toast"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mb-4 rounded-2xl bg-green-100 p-3 text-green-700"><%= success %></div>
      <% } %>
      <form action="/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" required class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500" placeholder="you@college.edu">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
          <input type="password" name="password" required class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500">
        </div>
        <button type="submit" class="w-full rounded-xl bg-indigo-600 py-3 font-medium text-white hover:bg-indigo-700">Login</button>
      </form>
      <p class="mt-5 text-center text-sm text-slate-600">Don't have an account? <a href="/register" class="font-medium text-indigo-600 hover:underline">Register</a></p>
    </div>
  </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
