<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <main class="flex flex-1 items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg">
      <div class="mb-6 text-center">
        <img src="/images/ramdeobaba-university-logo.png" alt="Ramdeobaba University" class="mx-auto h-20 w-20 rounded-full object-cover">
        <p class="mt-3 text-sm font-semibold text-slate-700">Ramdeobaba University Hostel</p>
      </div>
      <div class="mb-6">
        <div class="mb-3 inline-flex rounded-full bg-indigo-100 px-3 py-1 text-sm font-medium text-indigo-700">Email verification</div>
        <h1 class="text-3xl font-bold text-slate-900">Verify OTP</h1>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 rounded-2xl bg-red-100 p-3 text-red-700"><%= error %></div>
      <% } %>
      <% if (typeof noEmail !== 'undefined' && noEmail) { %>
        <div class="mb-4 rounded-2xl bg-amber-100 p-3 text-sm text-amber-800">Email could not be sent (check .env for Nodemailer). Your OTP was printed in the <strong>server console</strong> where you ran <code>npm run dev</code>. Look for the line showing your email and 6-digit OTP.</div>
      <% } %>
      <p class="text-slate-600 mb-4">Enter the 6-digit OTP sent to your email.</p>
      <form action="/verify-otp" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" required value="<%= typeof email !== 'undefined' ? email : '' %>" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">OTP</label>
          <input type="text" name="otp" required maxlength="6" pattern="[0-9]{6}" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500" placeholder="123456">
        </div>
        <button type="submit" class="w-full rounded-xl bg-indigo-600 py-3 font-medium text-white hover:bg-indigo-700">Verify</button>
      </form>
      <p class="mt-5 text-center text-sm text-slate-600"><a href="/login" class="font-medium text-indigo-600 hover:underline">Back to Login</a></p>
    </div>
  </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
