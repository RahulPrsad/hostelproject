<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <main class="flex flex-1 items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg">
      <div class="mb-6 text-center">
        <img src="/images/ramdeobaba-university-logo-small.png" alt="Ramdeobaba University" class="mx-auto h-20 w-20 rounded-full object-cover">
        <p class="mt-3 text-sm font-semibold text-slate-700">Ramdeobaba University Hostel</p>
      </div>
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-slate-900">Register</h1>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 rounded-2xl bg-red-100 p-3 text-red-700"><%= error %></div>
      <% } %>
      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Name</label>
          <input type="text" name="name" required value="<%= (formData && formData.name) || '' %>" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500" placeholder="Full name">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email (official)</label>
          <input type="email" name="email" required value="<%= (formData && formData.email) || '' %>" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500" placeholder="you@college.edu">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Password (min 6)</label>
          <input type="password" name="password" required minlength="6" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Parent Name</label>
          <input type="text" name="parentName" value="<%= (formData && formData.parentName) || '' %>" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Parent Phone</label>
          <input type="text" name="parentPhone" value="<%= (formData && formData.parentPhone) || '' %>" class="w-full rounded-xl border border-slate-300 px-3 py-3 focus:ring-2 focus:ring-indigo-500" placeholder="10-digit">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Branch</label>
          <select name="branch" required class="w-full rounded-xl border border-slate-300 bg-white px-3 py-3 focus:ring-2 focus:ring-indigo-500">
            <option value="">Select branch</option>
            <% (branchOptions || []).forEach(branch => { %>
              <option value="<%= branch %>" <%= formData && formData.branch === branch ? 'selected' : '' %>><%= branch %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Year</label>
          <select name="year" required class="w-full rounded-xl border border-slate-300 bg-white px-3 py-3 focus:ring-2 focus:ring-indigo-500">
            <option value="">Select year</option>
            <% (yearOptions || []).forEach(year => { %>
              <option value="<%= year %>" <%= formData && formData.year === year ? 'selected' : '' %>>Year <%= year %></option>
            <% }); %>
          </select>
        </div>
        <button type="submit" class="w-full rounded-xl bg-indigo-600 py-3 font-medium text-white hover:bg-indigo-700">Register &amp; Get OTP</button>
      </form>
      <p class="mt-5 text-center text-sm text-slate-600">Already have an account? <a href="/login" class="font-medium text-indigo-600 hover:underline">Login</a></p>
    </div>
  </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
