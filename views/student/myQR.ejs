<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My QR Code - Hostel Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>
  <div class="flex flex-1 flex-col md:flex-row">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">My QR Code</h1>
      <div class="bg-white rounded-lg shadow p-6 max-w-sm">
        <% if (user.qrCode) { %>
          <img src="<%= user.qrCode %>" alt="QR Code" class="w-64 h-64 mx-auto block border rounded">
          <div class="mt-4 grid grid-cols-1 gap-3">
            <a href="/student/my-qr/download" download="my-qr.png" target="_blank" rel="noopener" class="inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">Download QR Code</a>
            <a href="/student/my-qr/download" target="_blank" rel="noopener" class="inline-flex w-full items-center justify-center rounded-lg border border-gray-300 px-4 py-2 text-gray-700 hover:bg-gray-50">Open QR Code</a>
          </div>
        <% } else { %>
          <p class="text-gray-500">QR code not generated. Please complete verification.</p>
        <% } %>
      </div>
    </main>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
