<div id="photoViewerOverlay" class="fixed inset-0 z-50 hidden bg-black/80">
  <div class="flex h-full flex-col">
    <div class="flex items-center justify-end gap-2 p-3">
      <button type="button" id="photoViewerZoomOut" class="h-10 w-10 rounded-full bg-white/90 text-xl font-semibold text-gray-900 shadow hover:bg-white" aria-label="Zoom out">-</button>
      <button type="button" id="photoViewerZoomIn" class="h-10 w-10 rounded-full bg-white/90 text-xl font-semibold text-gray-900 shadow hover:bg-white" aria-label="Zoom in">+</button>
      <button type="button" id="photoViewerClose" class="h-10 w-10 rounded-full bg-white/90 text-sm font-semibold text-gray-900 shadow hover:bg-white" aria-label="Close">X</button>
    </div>
    <div class="flex min-h-0 flex-1 items-center justify-center overflow-auto px-4 pb-6">
      <img id="photoViewerImage" src="" alt="Equipment photo" class="max-h-full max-w-full rounded-lg object-contain shadow-2xl transition-transform duration-150">
    </div>
  </div>
</div>
